{
  "name": "cv-tsilva",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "GIT_COMMIT_HASH=$(git rev-parse --short HEAD) next dev",
    "build": "export GIT_COMMIT_HASH=$([ -n \"$VERCEL_GIT_COMMIT_SHA\" ] && echo \"${VERCEL_GIT_COMMIT_SHA:0:7}\" || git rev-parse --short HEAD) && npm run assemble && npm run generate:cv && next build",
    "build:local": "GALLERY_MODE=local npm run build",
    "sync": "npm run fetch:github && npm run assemble && npm run generate:cv",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "assemble": "GALLERY_MODE=r2 npx tsx ../scripts/assemble-cv-data.ts",
    "assemble:local": "GALLERY_MODE=local npx tsx ../scripts/assemble-cv-data.ts",
    "generate:cv": "npx tsx ../scripts/generate-cv.ts",
    "fetch:github": "npx tsx ../scripts/fetch-github.ts",
    "stats": "npx tsx ../scripts/count-technologies.ts"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.45.0",
    "@vercel/speed-insights": "^1.3.1",
    "next": "^15.5.14",
    "photoswipe": "^5.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.68",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "gray-matter": "^4.0.3",
    "postcss": "^8.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "next": "$next",
    "postcss": "$postcss"
  }
}
