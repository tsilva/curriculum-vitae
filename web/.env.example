# Gallery configuration
# Mode: 'local' or 'r2' (default is 'r2' for production builds)
GALLERY_MODE=r2

# R2 Public URL (only used when GALLERY_MODE=r2)
# This should be your custom domain or the R2 dev URL
R2_PUBLIC_URL=https://curriculum-vitae-r2.tsilva.eu

# Public gallery URL emitted into cv-data.json.
# Production uses same-origin URLs so Cloudflare and Vercel headers apply.
GALLERY_PUBLIC_URL=/galleries

# Optional cache token override. Defaults to the current git commit short hash.
# ASSET_CACHE_TOKEN=cache-token

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry
# Production is enabled by default when a DSN is set. Use NEXT_PUBLIC_SENTRY_ENABLED=true
# to opt into local or preview testing, or false to force-disable it.
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Optional server/runtime DSN. The current Vercel deployment is static export, so the
# browser DSN above is the live production requirement unless server routes are added later.
# SENTRY_DSN=https://examplePrivateKey@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_ENABLED=true
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Canonical production site URL used for metadata, sitemap, and robots
NEXT_PUBLIC_SITE_URL=https://www.tsilva.eu
